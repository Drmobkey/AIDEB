# =========================================================================
# AIDEB Configuration File (Copy to .env before building)
# =========================================================================

# Masukkan alamat URL / IP VPS Anda yang mengarah ke port backend (5003)
# Contoh: http://103.123.45.67:5003 atau https://api.aideb.com
NEXT_PUBLIC_API_URL=http://localhost:5003

# Kredensial Administrator
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password
